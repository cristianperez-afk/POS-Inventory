PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Choose the active database connection used by the backend.
DATABASE_TARGET=supabase
DB_POOL_MAX=1
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres?sslmode=no-verify"

# Optional local database connection if you run `npm run db:local`.
DATABASE_URL_LOCAL="postgresql://postgres:yourpassword@localhost:5432/bukolabs_pos"

# Supabase pooler connection if you run `npm run db:supabase`.
DATABASE_URL_SUPABASE="postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres?sslmode=no-verify"

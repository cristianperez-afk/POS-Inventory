  ingredient: string;
  action: 'remove' | 'add' | 'extra';
}

interface CartItem {
  id: number;
  name: string;
  price: number;
  quantity: number;
  image: string;
  orderType: 'dine-in' | 'takeout';
  notes: string;
  ingredients: Ingredient[];
  originalIngredients: Ingredient[];
}


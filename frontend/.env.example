# Frontend environment — copy to `.env`. No secrets here (VITE_* vars are
# bundled into the browser, so never put a secret in this file).
# The API base URL defaults to http://localhost:3000 in code, matching the
# backend's default port, so you normally don't need to set it.

VITE_ENABLE_INVENTORY_MODULES=true

# Optional local override (defaults to http://localhost:3000 in code):
# VITE_API_BASE_URL=http://localhost:3000

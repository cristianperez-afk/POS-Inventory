{
  "name": "bukolabs-pos-backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "node scripts/ensure-port-free.js && npm run build && node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:deploy": "node scripts/deploy-prisma.js",
    "db:local": "node scripts/switch-database.js local",
    "db:supabase": "node scripts/switch-database.js supabase",
    "db:seed-demo": "node scripts/seed-demo-accounts.js",
    "db:verify-demo": "node scripts/verify-demo-accounts.js",
    "db:fix-sequences": "node scripts/fix-sequences.js",
    "db:migrate-product-codes": "node scripts/migrate-numeric-product-codes.js",
    "db:merge-inventory": "node scripts/merge-inventory-database.js",
    "db:sync-inventory-catalog": "node scripts/sync-inventory-catalog.js",
    "db:repair-identity-links": "node scripts/repair-pos-inventory-identity-links.js",
    "db:normalize-categories": "node scripts/normalize-inventory-categories.js",
    "db:normalize-recipe-modifiers": "node scripts/normalize-recipe-modifiers.js",
    "db:merge-duplicates": "node scripts/merge-duplicate-inventory-items.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "16.4.7",
    "nodemailer": "^9.0.1",
    "pg": "8.13.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/node": "22.13.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "8.11.11",
    "prettier": "3.5.3",
    "prisma": "^7.8.0",
    "ts-node-dev": "2.0.0",
    "typescript": "5.8.3"
  }
}

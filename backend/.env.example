PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Choose the active database connection used by the backend.
DATABASE_TARGET=supabase
DB_POOL_MAX=1
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=no-verify"
JWT_SECRET="replace-with-a-long-random-secret"
FRONTEND_URL="http://127.0.0.1:5173"

# Optional SMTP settings for password reset email. If SMTP_HOST is empty, reset links are logged in the backend console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional local database connection if you run `npm run db:local`.
DATABASE_URL_LOCAL="postgresql://postgres:yourpassword@localhost:5432/bukolabs_pos"

# Supabase pooler connection if you run `npm run db:supabase`.
DATABASE_URL_SUPABASE="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=no-verify"

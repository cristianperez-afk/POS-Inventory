# =============================================================================
# Backend environment — copy this file to .env and fill in the SECRET below.
#
#   cp .env.example .env
#
# RULE: .env should contain SECRETS ONLY (the DATABASE_URL).
# All shared config (port, CORS, pool size, timeouts) comes from code defaults
# so every collaborator runs with identical settings — no more port/env drift.
# Only uncomment an override below if you intentionally need a local change.
# =============================================================================

# --- Required: the database connection (shared privately, NOT committed) ---
DATABASE_TARGET=supabase
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=no-verify"

# --- Optional local-only overrides (defaults shown; leave commented out) ----
# PORT=3000                            # backend port — defaults to 3000 in code
# CORS_ORIGIN=http://localhost:3003    # defaults to any localhost port in code
# DB_POOL_MAX=3                        # defaults to 3 in code
# DB_POOL_CONNECTION_TIMEOUT_MS=20000  # defaults to 20000 in code

# --- Optional alternate DB targets (only if you run db:local / db:supabase) --
# DATABASE_URL_LOCAL="postgresql://postgres:yourpassword@localhost:5432/bukolabs_pos"
# DATABASE_URL_SUPABASE="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=no-verify"

# --- Optional: migration connection for `prisma migrate deploy` ------------
# Prisma migrations should not use Supabase's transaction pooler (port 6543).
# On Render and other IPv4-only hosts, use Supabase's session pooler instead of
# the direct db.<project-ref>.supabase.co:5432 host. Direct Supabase connections
# require IPv6 unless the project has the IPv4 add-on enabled.
# DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres?sslmode=no-verify"
